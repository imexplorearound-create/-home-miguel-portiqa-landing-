# Mailchimp — para a API /api/subscribe (lista de espera Founding 50)
#
# Onde encontrar no Mailchimp:
#   API_KEY     → https://us21.admin.mailchimp.com/account/api/ (ou o teu server prefix)
#   AUDIENCE_ID → Mailchimp → Audience → Settings → "Audience name and defaults" → Audience ID
#
# IMPORTANTE — não comitar este ficheiro com valores reais.
# Copia para .env.local para teste local; em produção define em Vercel:
#   Project → Settings → Environment Variables → Add
#
# A audience tem de ter os seguintes merge fields configurados (Audience → Settings → Merge fields):
#   FNAME    (text, default)
#   LNAME    (text, default)
#   COMPANY  (text, custom — criar)
#   UNITS    (text, custom — criar)

MAILCHIMP_API_KEY=your-api-key-here-with-server-prefix
MAILCHIMP_AUDIENCE_ID=your-audience-id-here
